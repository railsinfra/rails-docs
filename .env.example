# API Key from http://app.stainless.com/org/default/settings
STAINLESS_API_KEY="stl_sk..."

# Optional: marketing site URL for the header "Website" link (defaults to http://localhost:3000)
# PUBLIC_MARKETING_SITE_URL="https://example.com"

# Optional: URL the header "Get started" button points to (defaults to "/").
# Use an absolute https:// URL when linking to an external app (e.g. dashboard).
# PUBLIC_GET_STARTED_URL="https://app.example.com/signup"

# Optional feature flag for the header "Get started" button.
# Truthy values: true | 1 | yes | on. Defaults to enabled when unset.
# PUBLIC_GET_STARTED_ENABLED="true"